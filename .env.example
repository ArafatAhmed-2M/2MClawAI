# 2M Claw Environment Configuration
PORT=3000
NODE_ENV=development

# Bot Tokens
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=


# Default provider for Telegram/Discord bots.
# Leave blank to AUTO-DETECT based on which API key is set below.
# Options: openrouter, groq, deepseek, together, claude, gemini, cohere, huggingface, ollama, custom, openai
DEFAULT_PROVIDER=
DEFAULT_MODEL=

# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
CLAUDE_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OLLAMA_ENDPOINT=http://localhost:11434
OPENROUTER_API_KEY=your_openrouter_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
COHERE_API_KEY=your_cohere_api_key_here
HF_API_KEY=your_huggingface_token_here
TOGETHER_API_KEY=your_together_api_key_here
CUSTOM_BASE_URL=
CUSTOM_API_KEY=

# Default Custom Models (Comma-separated)
OPENAI_MODELS=gpt-4o,gpt-5-turbo
CLAUDE_MODELS=claude-3-opus,claude-3-sonnet
GEMINI_MODELS=gemini-3.1-pro-preview,gemini-3-flash-preview,gemini-3.1-flash-lite,gemini-3.1-flash-image-preview
GROQ_MODELS=llama3-70b-8192,llama3-8b-8192
OLLAMA_MODELS=llama3,mistral
OPENROUTER_MODELS=nvidia/nemotron-3-super-120b-a12b:free,openai/gpt-oss-120b:free,google/gemma-4-26b-a4b-it:free,z-ai/glm-5.1
DEEPSEEK_MODELS=deepseek-chat,deepseek-coder
COHERE_MODELS=command-r-plus,command-r
HF_MODELS=meta-llama/Llama-3-70b-chat-hf
TOGETHER_MODELS=meta-llama/Llama-3-70b-chat-hf
CUSTOM_MODELS=

# Memory Settings
MEMORY_STORAGE_PATH=./data/memory.json
